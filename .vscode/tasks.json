{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run StressCare",
      "type": "shell",
      "command": "npm run dev:open",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "C:\\Windows\\System32\\cmd.exe",
          "args": [
            "/d",
            "/c"
          ]
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false,
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
